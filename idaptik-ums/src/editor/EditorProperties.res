}

/// Render zone marker-specific properties.
/// Shows zone name and security tier.
function zoneMarkerProperties(entity, dispatch) {
  var securityOptions = EditorModel.allSecurityLevels.map(function (sl) {
    return [sl, sl];
  });

  return [
    textRow("zname", "Zone Name", entity.properties.zoneName, function (v) {
      dispatch({ TAG: "UpdateProperty", _0: entity.id, _1: "zoneName", _2: v });
    }),
    selectRow("tier", "Security Tier", entity.properties.securityTier,
