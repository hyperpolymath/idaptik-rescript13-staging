/// Shows archetype (read-only) and altitude.
function droneProperties(entity, dispatch) {
  var archetype = entity.properties.droneArchetype || "Helper";

  return [
    infoRow("arch", "Archetype", EditorEngine.droneArchetypeLabel(archetype)),
