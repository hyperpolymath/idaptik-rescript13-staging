//  Language Code Lookup 

// Get the translation dictionary for a given language code
let getTranslations = (langCode: string): dict<string> => {
  switch langCode {
  | "es" => es
  | "fr" => fr
  | "de" => de
  | "ja" => ja
  | _ => en
  }
}
